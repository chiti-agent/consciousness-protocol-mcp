{
  "name": "consciousness-protocol-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI agent IP registration with blockchain provenance",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "consciousness-protocol": "dist/cli.js",
    "consciousness-protocol-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test tests/*.test.ts",
    "test:setup": "node --import tsx/esm tests/wallets/generate-wallets.ts && node --import tsx/esm tests/wallets/fund-wallets.ts && node --import tsx/esm tests/fixtures/generate.ts",
    "test:b": "node --import tsx/esm --test tests/level-b/*.test.ts",
    "test:c": "node --import tsx/esm --test tests/level-c/*.test.ts",
    "test:a": "node --import tsx/esm --test tests/level-a/*.test.ts",
    "test:all": "yarn test:setup && yarn test:b && yarn test:c && yarn test:a"
  },
  "keywords": [
    "mcp",
    "ai-agent",
    "ip",
    "blockchain",
    "near",
    "story-protocol"
  ],
  "author": "Chiti + Ivan Medvedev",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@story-protocol/core-sdk": "^1.4.4",
    "near-api-js": "^7.2.0",
    "viem": "^2.47.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
